<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.pedidoController"
           style="-fx-background-color: #f0f2f5;">

    <!-- ── CAMADA 1: Tabela ── -->
    <VBox spacing="24" style="-fx-padding: 24;">
        <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                     -fx-padding: 24;" VBox.vgrow="ALWAYS">

            <VBox spacing="4" style="-fx-padding: 0 0 20 0;">
                <Label text="Pedidos"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Clique em um pedido para ver os detalhes"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <HBox spacing="12" style="-fx-padding: 0 0 20 0;" alignment="CENTER_LEFT">
                <TextField fx:id="searchNum"
                           promptText="🔍  Buscar por número"
                           prefWidth="180" onKeyReleased="#onSearch"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px;"/>
                <TextField fx:id="searchSolicitante"
                           promptText="🔍  Buscar por solicitante"
                           prefWidth="200" onKeyReleased="#onSearch"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px;"/>
                <ComboBox fx:id="filtroStatus" promptText="Todos os status"
                          prefWidth="160" onAction="#onFiltroStatus"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-font-size: 13px;"/>
            </HBox>


                <TableView fx:id="tabelaPedidos" minWidth="800"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                  -fx-table-cell-border-color: transparent; -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colNum"       text="Nº Pedido"   prefWidth="100"/>
                        <TableColumn fx:id="colData"      text="Data"        prefWidth="140"/>
                        <TableColumn fx:id="colSolicitante" text="Solicitante" prefWidth="160"/>
                        <TableColumn fx:id="colSetor"     text="Setor"       prefWidth="120"/>
                        <TableColumn fx:id="colCentro"    text="Centro Custo" prefWidth="140"/>
                        <TableColumn fx:id="colValor"     text="Valor Total"  prefWidth="110"/>
                        <TableColumn fx:id="colStatus"    text="Status"       prefWidth="120"/>
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="70"/>
                    </columns>
                    <placeholder>
                        <Label text="Nenhum pedido encontrado."
                               style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>
        </VBox>
    </VBox>

    <!-- ── CAMADA 2: Overlay de detalhes ── -->
    <StackPane fx:id="overlayDetalhes" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.45);">

        <VBox spacing="0" maxWidth="620" maxHeight="560"
              style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 4);">

            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #2563eb;
                         -fx-background-radius: 16 16 0 0; -fx-padding: 20 20 16 20;">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Detalhes do Pedido"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #bfdbfe;"/>
                    <Label fx:id="detalheNum"
                           style="-fx-font-size: 17px; -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
                </VBox>
                <Button text="✕" onAction="#fecharDetalhes"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-font-size: 14px;
                               -fx-background-radius: 50; -fx-cursor: hand;
                               -fx-border-color: transparent; -fx-padding: 6 10;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;">
                <VBox spacing="0" style="-fx-padding: 20;">

                    <!-- Linha 1: Data + Status -->
                    <HBox spacing="24" style="-fx-padding: 0 0 16 0;
                          -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="DATA DE ABERTURA"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheData"
                                   style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="STATUS"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheStatus"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                                          -fx-background-radius: 6; -fx-padding: 4 12;"/>
                        </VBox>
                    </HBox>

                    <!-- Linha 2: Solicitante + Valor -->
                    <HBox spacing="24" style="-fx-padding: 16 0;
                          -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="SOLICITANTE"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheSolicitante"
                                   style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="VALOR TOTAL ESTIMADO"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheValor"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                    </HBox>

                    <!-- Linha 3: Setor + Centro de Custo -->
                    <HBox spacing="24" style="-fx-padding: 16 0;
                          -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="SETOR"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheSetor"
                                   style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="CENTRO DE CUSTO"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheCentro"
                                   style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        </VBox>
                    </HBox>

                    <!-- Produtos do pedido -->
                    <VBox spacing="8" style="-fx-padding: 16 0 0 0;">
                        <Label text="PRODUTOS DO PEDIDO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <TableView fx:id="tabelaItensPedido" prefHeight="160"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-font-size: 12px;">
                            <columns>
                                <TableColumn fx:id="colItemProduto"  text="Produto"    prefWidth="180"/>
                                <TableColumn fx:id="colItemUnidade"  text="Un."        prefWidth="50"/>
                                <TableColumn fx:id="colItemQtd"      text="Qtd"        prefWidth="60"/>
                                <TableColumn fx:id="colItemValorUnit" text="Vlr Unit."  prefWidth="90"/>
                                <TableColumn fx:id="colItemValorTotal" text="Vlr Total" prefWidth="100"/>
                            </columns>
                            <placeholder>
                                <Label text="Sem produtos."
                                       style="-fx-text-fill: #94a3b8;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>

            <HBox alignment="CENTER_RIGHT"
                  style="-fx-padding: 16 20;
                         -fx-border-color: #f1f5f9 transparent transparent transparent;
                         -fx-border-width: 1;">
                <Button text="Fechar" onAction="#fecharDetalhes"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </StackPane>
</StackPane>