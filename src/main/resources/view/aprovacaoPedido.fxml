<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.aprovacaoPedidoController"
            style="-fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                style="-fx-background:#f0f2f5; -fx-background-color:#f0f2f5; -fx-border-color:transparent;">

        <VBox spacing="20" style="-fx-padding: 28;">

            <!-- ── Cabeçalho ─────────────────────────────── -->
            <VBox spacing="4">
                <Label text="✅  Aprovação de Pedido"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label fx:id="labelSubtitulo" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
            </VBox>

            <!-- ── Card: Dados do Pedido ──────────────────── -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-color: #e5e7eb; -fx-border-radius: 12;
                         -fx-border-width: 1; -fx-padding: 20;">

                <Label text="Informações do Pedido"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>

                <HBox spacing="20">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Nº Pedido" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                        <TextField fx:id="fieldNumPedido" editable="false"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:8 12;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Solicitante" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                        <TextField fx:id="fieldSolicitante" editable="false"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:8 12;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Setor" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                        <TextField fx:id="fieldSetor" editable="false"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:8 12;"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Centro de Custo" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                        <TextField fx:id="fieldCentro" editable="false"
                                   style="-fx-background-color:#f9fafb; -fx-border-color:#e5e7eb;
                                          -fx-border-radius:8; -fx-background-radius:8; -fx-padding:8 12;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ── Card: Itens do Pedido ──────────────────── -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-color: #e5e7eb; -fx-border-radius: 12;
                         -fx-border-width: 1; -fx-padding: 20;">

                <Label text="Produtos do Pedido"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>

                <Label text="Defina a quantidade aprovada para cada item. Deixe 0 para reprovar um item específico."
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" wrapText="true"/>

                <TableView fx:id="tabelaItens" prefHeight="240"
                           style="-fx-background-color: white; -fx-border-color: #e5e7eb;
                                  -fx-border-radius: 8; -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colProduto"    text="Produto"        prefWidth="220"/>
                        <TableColumn fx:id="colUnidade"    text="Un."            prefWidth="60"/>
                        <TableColumn fx:id="colQtdSolic"   text="Qtd Solicitada" prefWidth="120"/>
                        <TableColumn fx:id="colVlrUnit"    text="Vlr Unit."      prefWidth="100"/>
                        <TableColumn fx:id="colVlrTotal"   text="Vlr Total"      prefWidth="100"/>
                        <TableColumn fx:id="colQtdAprov"   text="Qtd Aprovada *" prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <Label text="Nenhum item." style="-fx-text-fill: #9ca3af;"/>
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <Label text="Valor Total Aprovado:"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <Label fx:id="labelTotalAprovado"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                </HBox>
            </VBox>

            <!-- ── Card: Parecer ──────────────────────────── -->
            <VBox spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-border-color: #e5e7eb; -fx-border-radius: 12;
                         -fx-border-width: 1; -fx-padding: 20;">

                <Label text="Parecer" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <Label text="Obrigatório ao negar. Opcional ao aprovar."
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <TextArea fx:id="fieldParecer" promptText="Justificativa ou observações..."
                          prefRowCount="3" wrapText="true"
                          style="-fx-border-color:#d1d5db; -fx-border-radius:8;
                                 -fx-background-radius:8; -fx-padding:8 12; -fx-font-size:13px;"/>
                <Label fx:id="erroParecer" text=""
                       style="-fx-text-fill: #dc2626; -fx-font-size: 11px;"/>
            </VBox>

            <!-- ── Botões ──────────────────────────────────── -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#onCancelar"
                        style="-fx-background-color:#f1f5f9; -fx-text-fill:#475569;
                               -fx-background-radius:8; -fx-border-color:transparent;
                               -fx-padding:10 24; -fx-cursor:hand; -fx-font-size:13px;"/>
                <Button text="❌  Negar Pedido" onAction="#onNegar"
                        style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626;
                               -fx-font-weight:bold; -fx-background-radius:8;
                               -fx-border-color:transparent; -fx-padding:10 24;
                               -fx-cursor:hand; -fx-font-size:13px;"/>
                <Button text="✅  Aprovar Pedido" onAction="#onAprovar"
                        style="-fx-background-color:#2563eb; -fx-text-fill:white;
                               -fx-font-weight:bold; -fx-background-radius:8;
                               -fx-border-color:transparent; -fx-padding:10 24;
                               -fx-cursor:hand; -fx-font-size:13px;"/>
            </HBox>

        </VBox>
    </ScrollPane>
</AnchorPane>
