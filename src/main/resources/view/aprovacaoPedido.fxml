<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.aprovacaoPedidoController"
            style="-fx-background-color: #f0f2f5;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ── Barra superior com voltar e título ──────────── -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white; -fx-padding: 16 28;
                     -fx-border-color: transparent transparent #e5e7eb transparent;
                     -fx-border-width: 1;">
            <Button text="← Voltar" onAction="#onVoltar"
                    style="-fx-background-color:#f1f5f9; -fx-text-fill:#374151;
                           -fx-background-radius:8; -fx-border-color:transparent;
                           -fx-padding:8 16; -fx-cursor:hand; -fx-font-size:13px;"/>
            <VBox spacing="2">
                <Label text="Detalhes do Pedido"
                       style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#0f172a;"/>
                <Label fx:id="labelSubtitulo" text=""
                       style="-fx-font-size:13px; -fx-text-fill:#6b7280;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Badge de status do pedido -->
            <Label fx:id="badgeStatus" text=""
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-background-radius:8; -fx-padding:6 16;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background:#f0f2f5; -fx-background-color:#f0f2f5; -fx-border-color:transparent;">
            <VBox spacing="20" style="-fx-padding: 28;">

                <!-- ── Card: Informações do Pedido ───────────── -->
                <VBox spacing="16"
                      style="-fx-background-color:white; -fx-background-radius:12;
                             -fx-border-color:#e5e7eb; -fx-border-radius:12;
                             -fx-border-width:1; -fx-padding:24;">

                    <Label text="Informações do Pedido"
                           style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>

                    <HBox spacing="20">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Nº PEDIDO"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="fieldNumPedido"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a; -fx-font-weight:bold;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="DATA DE ABERTURA"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="fieldData"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="SOLICITANTE"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="fieldSolicitante"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="20">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="SETOR"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="fieldSetor"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="CENTRO DE CUSTO"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="fieldCentro"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="VALOR TOTAL ESTIMADO"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="fieldValor"
                                   style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#2563eb;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── Card: Produtos do Pedido ──────────────── -->
                <VBox spacing="12"
                      style="-fx-background-color:white; -fx-background-radius:12;
                             -fx-border-color:#e5e7eb; -fx-border-radius:12;
                             -fx-border-width:1; -fx-padding:24;">

                    <Label text="Produtos do Pedido"
                           style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>

                    <TableView fx:id="tabelaItens" prefHeight="220"
                               style="-fx-background-color:white; -fx-border-color:#e5e7eb;
                                      -fx-border-radius:8; -fx-background-radius:8; -fx-font-size:13px;">
                        <columns>
                            <TableColumn fx:id="colProduto"  text="Produto"          prefWidth="250"/>
                            <TableColumn fx:id="colUnidade"  text="Un."              prefWidth="60"/>
                            <TableColumn fx:id="colQtdSolic" text="Qtd Solicitada"   prefWidth="130"/>
                            <TableColumn fx:id="colVlrUnit"  text="Vlr Unit."        prefWidth="110"/>
                            <TableColumn fx:id="colQtdAprov"  text="Qtd Aprov."   prefWidth="110"/>
                            <TableColumn fx:id="colVlrTotal" text="Vlr Total"        prefWidth="120"/>

                        </columns>
                        <placeholder>
                            <Label text="Nenhum item." style="-fx-text-fill:#9ca3af;"/>
                        </placeholder>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT">
                        <Label text="Valor Total Estimado:  "
                               style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <Label fx:id="labelTotal"
                               style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#2563eb;"/>
                    </HBox>
                </VBox>

                <!-- ── Card: Aprovação/Negação (só aparece para DIRETOR e só EM_APROVACAO) ── -->
                <VBox fx:id="cardAprovacao" spacing="12"
                      visible="false" managed="false"
                      style="-fx-background-color:white; -fx-background-radius:12;
                             -fx-border-color:#e5e7eb; -fx-border-radius:12;
                             -fx-border-width:1; -fx-padding:24;">

                    <Label text="Decisão"
                           style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                    <Label text="Obrigatório para aprovar ou negar."
                           style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>

                    <TextArea fx:id="fieldParecer"
                              promptText="Informe o parecer ou justificativa..."
                              prefRowCount="3" wrapText="true"
                              style="-fx-border-color:#d1d5db; -fx-border-radius:8;
                                     -fx-background-radius:8; -fx-padding:8 12; -fx-font-size:13px;"/>
                    <Label fx:id="erroParecer" text=""
                           style="-fx-text-fill:#dc2626; -fx-font-size:11px;"/>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="❌  Negar Pedido" onAction="#onNegar"
                                style="-fx-background-color:#fee2e2; -fx-text-fill:#dc2626;
                                       -fx-font-weight:bold; -fx-background-radius:8;
                                       -fx-border-color:transparent; -fx-padding:10 24;
                                       -fx-cursor:hand; -fx-font-size:13px;"/>
                        <Button text="✅  Aprovar Pedido" onAction="#onAprovar"
                                style="-fx-background-color:#2563eb; -fx-text-fill:white;
                                       -fx-font-weight:bold; -fx-background-radius:8;
                                       -fx-border-color:transparent; -fx-padding:10 24;
                                       -fx-cursor:hand; -fx-font-size:13px;"/>
                    </HBox>
                </VBox>

                <!-- ── Card: Resultado da aprovação (visível para todos após decisão) ── -->
                <VBox fx:id="cardResultado" spacing="12"
                      visible="false" managed="false"
                      style="-fx-background-color:white; -fx-background-radius:12;
                             -fx-border-color:#e5e7eb; -fx-border-radius:12;
                             -fx-border-width:1; -fx-padding:24;">

                    <Label text="Resultado da Aprovação"
                           style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>

                    <HBox spacing="20">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="APROVADO/NEGADO POR"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="labelAprovador"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a;"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="DATA DA DECISÃO"
                                   style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                            <Label fx:id="labelDataAprovacao"
                                   style="-fx-font-size:14px; -fx-text-fill:#0f172a;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="4">
                        <Label text="PARECER"
                               style="-fx-font-size:11px; -fx-font-weight:bold; -fx-text-fill:#94a3b8;"/>
                        <Label fx:id="labelParecer" wrapText="true"
                               style="-fx-font-size:14px; -fx-text-fill:#374151;"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
