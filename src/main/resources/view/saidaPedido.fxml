<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #f0f2f5;"
	xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="api.controller.SaidaPedidoController">

	<VBox spacing="24" style="-fx-padding: 24;">
		<!-- Container Principal -->
		<VBox
			style="-fx-background-color: white; -fx-background-radius: 12;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);                      -fx-padding: 24;"
			VBox.vgrow="ALWAYS">

			<!-- Cabeçalho da Tela -->
			<VBox spacing="4" style="-fx-padding: 0 0 20 0;">
				<Label
					style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"
					text="Gerenciar Saída de Pedidos" />
				<Label style="-fx-font-size: 13px; -fx-text-fill: #475569;"
					text="Selecione um pedido e informe a quantidade para retirada no estoque." />
			</VBox>

			<!-- Barra de Ferramentas/Busca -->
			<HBox alignment="CENTER_LEFT" spacing="12"
				style="-fx-padding: 0 0 20 0;">
				<TextField fx:id="txtBuscaPedido" prefWidth="250"
					promptText="🔍  Buscar por ID ou Produto"
					style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;                                   -fx-border-radius: 8; -fx-background-radius: 8;                                   -fx-padding: 10 14; -fx-font-size: 13px;" />

				<Region HBox.hgrow="ALWAYS" />

				<!-- Área de Ação Lateral -->
				<HBox alignment="CENTER_RIGHT" spacing="10">
					<VBox spacing="2">
						<TextField fx:id="txtQuantidadeSaida" prefWidth="120"
							promptText="Qtd. Saída"
							style="-fx-background-color: #ffffff; -fx-border-color: #2563eb;                                           -fx-border-radius: 8; -fx-background-radius: 8;                                           -fx-padding: 9 12; -fx-font-size: 13px;" />
					</VBox>
					<Button fx:id="btnRegistrarSaida"
						onAction="#handleRegistrarSaida"
						style="-fx-background-color: #2563eb; -fx-text-fill: white;                                    -fx-font-weight: bold; -fx-background-radius: 8;                                    -fx-padding: 10 20; -fx-cursor: hand;"
						text="Retirar" />
				</HBox>
			</HBox>

			<!-- Tabela Principal -->
			<ScrollPane fitToHeight="true" fitToWidth="true"
				style="-fx-background-color: transparent; -fx-background: transparent;                                -fx-border-color: transparent;"
				VBox.vgrow="ALWAYS">
				<TableView fx:id="pedidosTable"
					style="-fx-background-color: transparent; -fx-border-color: transparent;                                   -fx-table-cell-border-color: transparent; -fx-font-size: 13px;">
					<columns>
						<TableColumn fx:id="colID" prefWidth="100"
							text="ID Pedido" />
						<TableColumn fx:id="colProduto" prefWidth="300"
							text="Produto" />
						<TableColumn fx:id="colQuantidade" prefWidth="150"
							text="Qtd. Solicitada" />
						<TableColumn fx:id="colStatus" prefWidth="150"
							text="Status" />
					</columns>
					<columnResizePolicy>
						<TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
					</columnResizePolicy>
					<placeholder>
						<Label style="-fx-text-fill: #475569; -fx-font-size: 13px;"
							text="Nenhum item pendente de saída." />
					</placeholder>
				</TableView>
			</ScrollPane>

			<!-- Rodapé com botões de Ação -->
			<HBox alignment="CENTER_RIGHT" spacing="12"
				style="-fx-padding: 20 0 0 0;                           -fx-border-color: #f1f5f9 transparent transparent transparent;                           -fx-border-width: 1;">
				<Button onAction="#voltarMenuPrincipal"
					style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;                                -fx-font-size: 13px; -fx-font-weight: bold;                                -fx-background-radius: 8; -fx-padding: 10 24;                                -fx-cursor: hand; -fx-border-color: transparent;"
					text="Cancelar" />
			</HBox>

		</VBox>
	</VBox>
</StackPane>
