<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.cadastroCompraController"
            style="-fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="20" style="-fx-padding: 24;" minWidth="820">

            <!-- ── Título ──────────────────────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Button text="← Voltar" onAction="#onVoltar"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-border-color: transparent;
                               -fx-padding: 8 18; -fx-cursor: hand;"/>
                <VBox spacing="2">
                    <Label text="Registrar Compra"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Cadastre uma ou mais compras para os itens pendentes do pedido"
                           style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
                </VBox>
            </HBox>

            <!-- ── Card: Resumo do Pedido ──────────────────────────────────── -->
            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Pedido"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="labelNumPedido" text=""
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                    <Label fx:id="labelStatusPedido" text=""
                           style="-fx-font-size: 11px; -fx-font-weight: bold;
                                  -fx-background-radius: 6; -fx-padding: 4 12;"/>
                </HBox>

                <HBox spacing="32"
                      style="-fx-border-color: transparent transparent #f1f5f9 transparent;
                             -fx-border-width: 1; -fx-padding: 0 0 16 0;">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="SOLICITANTE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelSolicitante" text="—"
                               style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="SETOR"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelSetor" text="—"
                               style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                </HBox>

                <Label fx:id="labelAviso" text=""
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- ── Card: Nova Compra ───────────────────────────────────────── -->
            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Nova Compra"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <!-- Fornecedor + Data prevista -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Fornecedor *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="comboFornecedor"
                                  promptText="Selecione o fornecedor"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="200">
                        <Label text="Data de Entrega Prevista"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <DatePicker fx:id="dataEntregaPrevista" maxWidth="Infinity"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                           -fx-border-radius: 8; -fx-background-radius: 8;
                                           -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Tabela de itens pendentes -->
                <Label text="ITENS PENDENTES DE COMPRA"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;
                              -fx-padding: 8 0 0 0;"/>

                <TableView fx:id="tabelaItens" editable="true" prefHeight="220"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colProduto"   text="Produto"       prefWidth="220"/>
                        <TableColumn fx:id="colUnidade"   text="Un."           prefWidth="55"/>
                        <TableColumn fx:id="colPendente"  text="Qtd Pendente"  prefWidth="110"/>
                        <TableColumn fx:id="colQtdCompra" text="Qtd a Comprar" prefWidth="120"/>
                        <TableColumn fx:id="colValorUnit" text="Valor Unit."   prefWidth="110"/>
                        <TableColumn fx:id="colTotal"     text="Valor Total"   prefWidth="120"/>
                        <TableColumn fx:id="colRemover"   text=""              prefWidth="55"/>
                    </columns>
                    <placeholder>
                        <Label text="Todos os itens do pedido já possuem compra cadastrada."
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>

                <!-- Total + Botão salvar -->
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <HBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Total desta compra:"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label fx:id="labelTotalNova" text="R$ 0,00"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                    </HBox>
                    <Button text="✔  Registrar Compra" onAction="#onSalvar"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-border-color: transparent;
                                   -fx-padding: 10 28; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- ── Card: Compras já registradas ───────────────────────────── -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Compras Já Registradas para Este Pedido"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <TableView fx:id="tabelaComprasExistentes" prefHeight="190"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colCompraNum"        text="ID"          prefWidth="60"/>
                        <TableColumn fx:id="colCompraData"       text="Data"        prefWidth="140"/>
                        <TableColumn fx:id="colCompraFornecedor" text="Fornecedor"  prefWidth="200"/>
                        <TableColumn fx:id="colCompraValor"      text="Valor Total" prefWidth="130"/>
                        <TableColumn fx:id="colCompraStatus"     text="Status"      prefWidth="110"/>
                        <TableColumn fx:id="colCompraCancelar"   text=""            prefWidth="105"/>
                    </columns>
                    <placeholder>
                        <Label text="Nenhuma compra registrada para este pedido."
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</AnchorPane>
