<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.cadastroProdutoController"
            style="-fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true"
                hbarPolicy="AS_NEEDED"
                vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="20" style="-fx-padding: 24;" minWidth="600">

            <!-- Título -->
            <VBox spacing="4">
                <Label text="Cadastro de Produto"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Preencha os dados do novo produto"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <!-- Card -->
            <VBox spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <!-- Linha 1: Nome e Unidade -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nome do Produto *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldProduto"
                                   promptText="Ex: Parafuso M6"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="erroProduto" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="6" prefWidth="160">
                        <Label text="Unidade de Medida *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldUnidade" promptText="Selecione"
                                  prefWidth="160"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroUnidade" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <!-- Linha 2: Descrição -->
                <VBox spacing="6">
                    <Label text="Descrição *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <TextArea fx:id="fieldDescricao"
                              promptText="Descreva o produto (máx. 155 caracteres)"
                              prefHeight="80" wrapText="true"
                              style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    <HBox>
                        <Label fx:id="erroDescricao" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="contadorDescricao" text="0/155"
                               style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                    </HBox>
                </VBox>

                <!-- Linha 3: Nível Mínimo, Valor e Status -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nível Mínimo *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldNivelMinimo"
                                   promptText="Ex: 10"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="erroNivelMinimo" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Valor Estimado (R$) *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldValorEstimado"
                                   promptText="Ex: 99,90"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="erroValorEstimado" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="6" prefWidth="160">
                        <Label text="Status *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldStatus" promptText="Selecione"
                                  prefWidth="160"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroStatus" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <!-- Botões -->
                <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                    <Button text="Cancelar" onAction="#onCancelar"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 10 24;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                    <Button text="Salvar Produto" onAction="#onSalvar"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 10 24;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>