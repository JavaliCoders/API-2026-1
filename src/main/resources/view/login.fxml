<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #0a0f1e, #0d2b6b, #1a4db5);">

    <!-- Card central — largura e altura fixas, sempre centralizado -->
    <VBox alignment="CENTER" spacing="0"
          maxWidth="420" minWidth="420"
          maxHeight="520" minHeight="520"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 30, 0, 0, 8);
                 -fx-padding: 48 40 40 40;">

        <!-- Ícone de login -->
        <StackPane style="-fx-background-color: #2563eb; -fx-background-radius: 16;
                          -fx-min-width: 64; -fx-min-height: 64;
                          -fx-max-width: 64; -fx-max-height: 64;">
            <Label text="→"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        </StackPane>

        <Region prefHeight="20"/>

        <!-- Título -->
        <Label text="Bem-vindo de volta"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

        <Region prefHeight="6"/>

        <!-- Subtítulo -->
        <Label text="Entre com suas credenciais para acessar o sistema"
               style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-wrap-text: true;"
               maxWidth="300" textAlignment="CENTER"/>

        <Region prefHeight="32"/>

        <!-- Formulário -->
        <VBox spacing="16" maxWidth="340" fillWidth="true">

            <!-- Campo Usuário -->
            <VBox spacing="6">
                <Label text="Usuário"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <TextField fx:id="fieldUsuario"
                           promptText="seu.usuario"
                           onAction="#onEntrar"
                           onKeyReleased="#aoDigitar"
                           style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;
                                  -fx-background-radius: 10; -fx-border-radius: 10;
                                  -fx-padding: 12 16; -fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
            </VBox>

            <!-- Campo Senha -->
            <VBox spacing="6">
                <Label text="Senha"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <PasswordField fx:id="fieldSenha"
                               promptText="••••••••"
                               onAction="#onEntrar"
                               onKeyReleased="#aoDigitar"
                               style="-fx-background-color: #f1f5f9; -fx-border-color: transparent;
                                      -fx-background-radius: 10; -fx-border-radius: 10;
                                      -fx-padding: 12 16; -fx-font-size: 14px;"/>
            </VBox>

            <!-- Mensagem de erro -->
            <Label fx:id="labelErro" text=""
                   visible="false" managed="false"
                   style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-font-weight: bold;"
                   maxWidth="Infinity"/>

            <Region prefHeight="8"/>

            <!-- Botão Entrar -->
            <Button text="Entrar" onAction="#onEntrar"
                    maxWidth="Infinity" prefHeight="46"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;
                           -fx-border-color: transparent;"/>
        </VBox>

    </VBox>
</StackPane>
