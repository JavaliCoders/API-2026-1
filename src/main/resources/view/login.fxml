<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.effect.GaussianBlur?>

<StackPane prefHeight="720.0" prefWidth="1092.0"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.LoginController"
           style="-fx-background-color: #050d1a;">

    <!-- Imagem de fundo desfocada -->
    <ImageView fitWidth="1092" fitHeight="720"
               preserveRatio="false" pickOnBounds="false"
               opacity="0.38">
        <image>
            <Image url="@../images/login-background.png"/>
        </image>
        <effect>
            <GaussianBlur radius="14"/>
        </effect>
    </ImageView>

    <!-- Gradiente azul sobre o fundo -->
    <Region prefWidth="1092" prefHeight="720"
            style="-fx-background-color:
                linear-gradient(to bottom right,
                    rgba(4, 10, 30, 0.75) 0%,
                    rgba(8, 30, 90, 0.65) 50%,
                    rgba(15, 55, 160, 0.50) 100%);"/>

    <!-- Layout: branding esquerda + card direita -->
    <HBox alignment="CENTER" spacing="80">

        <!-- Branding esquerdo -->
        <VBox alignment="CENTER_LEFT" spacing="14" maxWidth="360">
            <Label text="TRANSFORMANDO"
                   style="-fx-text-fill: white;
                          -fx-font-family: 'Segoe UI Black', Arial;
                          -fx-font-size: 34px; -fx-font-weight: 900;"/>
            <Label text="ENTREGAS EM"
                   style="-fx-text-fill: white;
                          -fx-font-family: 'Segoe UI Black', Arial;
                          -fx-font-size: 34px; -fx-font-weight: 900;
                          -fx-padding: -10 0 0 0;"/>
            <Label text="IMPACTO POSITIVO"
                   style="-fx-text-fill: #60a5fa;
                          -fx-font-family: 'Segoe UI Black', Arial;
                          -fx-font-size: 34px; -fx-font-weight: 900;
                          -fx-padding: -10 0 0 0;"/>
            <Region prefHeight="6"/>
            <Label text="Sistema de Gestão de Compras"
                   style="-fx-text-fill: rgba(180,210,255,0.65);
                          -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>
        </VBox>

        <!-- Card compacto centralizado verticalmente -->
        <StackPane alignment="CENTER" maxHeight="480" minHeight="0">

            <VBox alignment="CENTER" spacing="0"
                  maxWidth="360" minWidth="360"
                  style="-fx-background-color: rgba(4, 12, 40, 0.82);
                         -fx-background-radius: 18;
                         -fx-border-color: rgba(255,255,255,0.13);
                         -fx-border-width: 1;
                         -fx-border-radius: 18;
                         -fx-padding: 32 36 32 36;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.70), 40, 0, 0, 14);">

                <!-- Logo com fundo branco -->
                <StackPane maxWidth="240" minWidth="240"
                           maxHeight="80" minHeight="80"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 10;
                                  -fx-padding: 10 22;">
                    <ImageView fitWidth="196" fitHeight="60"
                               preserveRatio="true" pickOnBounds="true"
                               smooth="true">
                        <image>
                            <Image url="@../images/newe-logo-hires-transparent.png"/>
                        </image>
                    </ImageView>
                </StackPane>

                <Region prefHeight="22"/>

                <Label text="Bem-vindo de volta"
                       style="-fx-text-fill: white; -fx-font-size: 22px;
                              -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

                <Region prefHeight="5"/>

                <Label text="Entre com suas credenciais"
                       style="-fx-text-fill: rgba(170,200,255,0.60);
                              -fx-font-size: 14px; -fx-font-family: 'Segoe UI';"/>

                <Region prefHeight="26"/>

                <!-- Campo Usuário -->
                <VBox spacing="7" maxWidth="280" minWidth="280">
                    <Label text="Usuário"
                           style="-fx-text-fill: rgba(200,218,255,0.85);
                                  -fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI';"/>
                    <TextField fx:id="fieldUsuario"
                               promptText="seu.usuario"
                               onAction="#onEntrar"
                               onKeyReleased="#aoDigitar"
                               prefHeight="46"
                               style="-fx-background-color: rgba(255,255,255,0.07);
                                      -fx-border-color: rgba(255,255,255,0.18);
                                      -fx-border-width: 1;
                                      -fx-background-radius: 10; -fx-border-radius: 10;
                                      -fx-padding: 0 16; -fx-font-size: 15px;
                                      -fx-text-fill: white;
                                      -fx-prompt-text-fill: rgba(180,200,255,0.38);"/>
                </VBox>

                <Region prefHeight="14"/>

                <!-- Campo Senha -->
                <VBox spacing="7" maxWidth="280" minWidth="280">
                    <Label text="Senha"
                           style="-fx-text-fill: rgba(200,218,255,0.85);
                                  -fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI';"/>
                    <PasswordField fx:id="fieldSenha"
                                   promptText="••••••••"
                                   onAction="#onEntrar"
                                   onKeyReleased="#aoDigitar"
                                   prefHeight="46"
                                   style="-fx-background-color: rgba(255,255,255,0.07);
                                          -fx-border-color: rgba(255,255,255,0.18);
                                          -fx-border-width: 1;
                                          -fx-background-radius: 10; -fx-border-radius: 10;
                                          -fx-padding: 0 16; -fx-font-size: 15px;
                                          -fx-text-fill: white;
                                          -fx-prompt-text-fill: rgba(180,200,255,0.38);"/>
                </VBox>

                <Region prefHeight="8"/>

                <!-- Erro -->
                <Label fx:id="labelErro"
                       text="" visible="false" managed="false"
                       wrapText="true" maxWidth="280"
                       style="-fx-text-fill: #fca5a5; -fx-font-size: 13px;
                              -fx-font-weight: bold; -fx-font-family: 'Segoe UI';
                              -fx-background-color: rgba(239,68,68,0.18);
                              -fx-background-radius: 8; -fx-padding: 8 12;"/>

                <Region prefHeight="22"/>

                <!-- Botão -->
                <Button text="Entrar" onAction="#onEntrar"
                        defaultButton="true"
                        prefHeight="48" maxWidth="280" minWidth="280"
                        style="-fx-background-color: #2563eb;
                               -fx-text-fill: white;
                               -fx-font-size: 16px; -fx-font-weight: bold;
                               -fx-font-family: 'Segoe UI';
                               -fx-background-radius: 10;
                               -fx-border-color: transparent;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.50), 16, 0, 0, 4);"/>

            </VBox>
        </StackPane>

    </HBox>

</StackPane>
