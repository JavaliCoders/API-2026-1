<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane
	style="-fx-background-color: #f0f2f5; -fx-background-radius: 16 16; -fx-border-radius: 16 16;"
	xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="api.controller.CotacaoController">

	<!-- Card Centralizado -->
	<VBox maxHeight="620" maxWidth="550" spacing="0"
		style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);">

		<!-- Cabeçalho Azul -->
		<VBox spacing="4"
			style="-fx-background-radius: 16 16; -fx-background-color: #2563eb; -fx-border-radius: 16; -fx-padding: 24;">
			<Label style="-fx-font-size: 14px; -fx-text-fill: #bfdbfe;"
				text="Processo de Compra" />
			<Label
				style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"
				text="Registrar Nova Cotação" />
		</VBox>

		<!-- Conteúdo do Formulário -->
		<VBox spacing="20" style="-fx-padding: 24;">

			<GridPane hgap="15" vgap="18">
				<columnConstraints>
					<ColumnConstraints minWidth="100" prefWidth="120" />
					<ColumnConstraints hgrow="ALWAYS" />
				</columnConstraints>

				<children>
					<!-- Fornecedor -->
					<VBox spacing="5" GridPane.columnIndex="0"
						GridPane.columnSpan="2" GridPane.rowIndex="0">
						<Label
							style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"
							text="FORNECEDOR" />
						<TextField fx:id="txtFornecedor"
							promptText="Nome da empresa ou fornecedor"
							style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
					</VBox>

					<!-- Valor -->
					<VBox spacing="5" GridPane.columnIndex="0"
						GridPane.rowIndex="1">
						<Label
							style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"
							text="VALOR (R$)" />
						<TextField fx:id="txtValor" promptText="0,00"
							style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
					</VBox>

					<!-- Data -->
					<VBox spacing="5" GridPane.columnIndex="1"
						GridPane.rowIndex="1">
						<Label
							style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"
							text="DATA DA COTAÇÃO" />
						<DatePicker fx:id="dpDataCotacao" maxWidth="Infinity"
							style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-padding: 5;" />
					</VBox>

					<!-- Observação -->
					<VBox spacing="5" GridPane.columnIndex="0"
						GridPane.columnSpan="2" GridPane.rowIndex="2">
						<Label
							style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"
							text="OBSERVAÇÕES" />
						<TextArea fx:id="txtObservacao" prefHeight="80"
							promptText="Escreva detalhes sobre as condições de pagamento ou entrega..."
							style="-fx-control-inner-background: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-radius: 8;"
							wrapText="true" />
					</VBox>

					<!-- Anexo Documento -->
					<VBox spacing="5" GridPane.columnIndex="0"
						GridPane.columnSpan="2" GridPane.rowIndex="3">
						<Label
							style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"
							text="DOCUMENTO DE COTAÇÃO (ANEXO)" />
						<HBox alignment="CENTER_LEFT" spacing="12"
							style="-fx-background-color: #f1f5f9; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-style: dashed; -fx-border-radius: 8;">
							<Button onAction="#handleAnexarDocumento"
								style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"
								text="Selecionar PDF/Imagem" />
							<Label fx:id="lblArquivoAnexado"
								style="-fx-font-size: 12px; -fx-text-fill: #475569;"
								text="Nenhum arquivo anexado" />
						</HBox>
					</VBox>
				</children>
				<rowConstraints>
					<RowConstraints />
					<RowConstraints />
					<RowConstraints />
					<RowConstraints />
				</rowConstraints>
			</GridPane>
		</VBox>

		<!-- Rodapé -->
		<HBox alignment="CENTER_RIGHT" spacing="12"
			style="-fx-padding: 20 24; -fx-background-color: #f8fafc; -fx-background-radius: 16 16 0 0; -fx-border-color: #e2e8f0 transparent transparent transparent;">
			<Button
				style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold;"
				text="Cancelar" />
			<Button onAction="#handleRegistrarCotacao"
				style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 12 24; -fx-cursor: hand;"
				text="Confirmar e Notificar Diretor" />
		</HBox>
	</VBox>
</StackPane>
