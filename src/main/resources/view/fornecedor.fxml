<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.fornecedorController"
           style="-fx-background-color: #f0f2f5;">

    <!-- ── CAMADA 1: Tabela ── -->
    <VBox spacing="24" style="-fx-padding: 24;">

        <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                     -fx-padding: 24;" VBox.vgrow="ALWAYS">

            <VBox spacing="4" style="-fx-padding: 0 0 20 0;">
                <Label text="Fornecedores"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Clique em um fornecedor para ver os detalhes"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <HBox spacing="12" style="-fx-padding: 0 0 20 0;" alignment="CENTER_LEFT">
                <TextField fx:id="searchCod"
                           promptText="🔍  Buscar por COD"
                           prefWidth="150" onKeyReleased="#onSearch"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                <TextField fx:id="searchNome"
                           promptText="🔍  Buscar por nome"
                           prefWidth="220" onKeyReleased="#onSearch"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                <ComboBox fx:id="filtroStatus" promptText="Todos os status"
                          prefWidth="150" onAction="#onFiltroStatus"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-font-size: 13px;"/>
            </HBox>

            <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;">
                <TableView fx:id="tabelaFornecedores" minWidth="700"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                  -fx-table-cell-border-color: transparent; -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colId"              text="COD"              prefWidth="65"/>
                        <TableColumn fx:id="colNome"            text="Nome"             prefWidth="180"/>
                        <TableColumn fx:id="colCnpj"            text="CNPJ"             prefWidth="140"/>
                        <TableColumn fx:id="colFormasPagamento" text="Formas Pagamento" prefWidth="200"/>
                        <TableColumn fx:id="colPedidoMinimo"    text="Pedido Mín."      prefWidth="110"/>
                        <TableColumn fx:id="colStatus"          text="Status"           prefWidth="90"/>
                        <TableColumn fx:id="colAcoes"           text="Ações"            prefWidth="65"/>
                    </columns>
                    <placeholder>
                        <Label text="Nenhum fornecedor cadastrado."
                               style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>
            </ScrollPane>
        </VBox>
    </VBox>

    <!-- ── CAMADA 2: Overlay de detalhes ── -->
    <StackPane fx:id="overlayDetalhes"
               visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.45);">

        <VBox spacing="0" maxWidth="520" maxHeight="500"
              style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 4);">

            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #2563eb;
                         -fx-background-radius: 16 16 0 0; -fx-padding: 20 20 16 20;">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Detalhes do Fornecedor"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #bfdbfe;"/>
                    <Label fx:id="detalheNome"
                           style="-fx-font-size: 17px; -fx-font-weight: bold;
                                  -fx-text-fill: white; -fx-wrap-text: true;"/>
                </VBox>
                <Button text="✕" onAction="#fecharDetalhes"
                        style="-fx-background-color: rgba(255,255,255,0.2);
                               -fx-text-fill: white; -fx-font-size: 14px;
                               -fx-background-radius: 50; -fx-cursor: hand;
                               -fx-border-color: transparent; -fx-padding: 6 10;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;
                               -fx-border-color: transparent;">
                <VBox spacing="0" style="-fx-padding: 20;">

                    <!-- Linha 1: COD + CNPJ -->
                    <HBox spacing="24" style="-fx-padding: 0 0 16 0;
                          -fx-border-color: transparent transparent #f1f5f9 transparent;
                          -fx-border-width: 1;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="COD"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheCod"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="CNPJ"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheCnpj"
                                   style="-fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
                        </VBox>
                    </HBox>

                    <!-- Linha 2: Formas de Pagamento + Pedido Mínimo -->
                    <HBox spacing="24" style="-fx-padding: 16 0;
                          -fx-border-color: transparent transparent #f1f5f9 transparent;
                          -fx-border-width: 1;">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="FORMAS DE PAGAMENTO"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheFormasPagamento"
                                   style="-fx-font-size: 14px; -fx-text-fill: #0f172a; -fx-wrap-text: true;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="PEDIDO MÍNIMO"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalhePedidoMinimo"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        </VBox>
                    </HBox>

                    <!-- Linha 3: Status -->
                    <HBox spacing="24" style="-fx-padding: 16 0 0 0;">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="STATUS"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detalheStatus"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold;
                                          -fx-background-radius: 6; -fx-padding: 4 12;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>

            <HBox alignment="CENTER_RIGHT"
                  style="-fx-padding: 16 20;
                         -fx-border-color: #f1f5f9 transparent transparent transparent;
                         -fx-border-width: 1;">
                <Button text="Fechar" onAction="#fecharDetalhes"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </StackPane>
</StackPane>