<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    StackPane raiz: permite empilhar o overlay de detalhes sobre a tabela.
-->
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.movimentacaoController"
           style="-fx-background-color: #f0f2f5;">

    <!-- ── CAMADA 1: Conteúdo principal ── -->
    <VBox spacing="24" style="-fx-padding: 24;">
        <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                     -fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- Título + botão nova movimentação manual -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Movimentações de Estoque"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Clique em uma linha para ver os detalhes da movimentação"
                           style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
                </VBox>
                <Button fx:id="btnNovaManual" text="+ Nova Movimentação Manual"
                        onAction="#onNovaManual"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-padding: 10 20; -fx-cursor: hand; -fx-border-color: transparent;
                               -fx-font-size: 13px;"/>
            </HBox>

            <!-- Filtros -->
            <HBox spacing="12" style="-fx-padding: 0 0 20 0;" alignment="CENTER_LEFT">
                <TextField fx:id="fieldBusca"
                           promptText="🔍  Buscar por produto, usuário ou pedido"
                           prefWidth="280"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                <ComboBox fx:id="filtroTipo"
                          promptText="Todos os tipos" prefWidth="170"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                <DatePicker fx:id="filtroDataInicio"
                            promptText="Data início" prefWidth="145"
                            style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                   -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                <DatePicker fx:id="filtroDataFim"
                            promptText="Data fim" prefWidth="145"
                            style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                   -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                <Button text="Limpar" onAction="#onLimparFiltros"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                               -fx-background-radius: 8; -fx-border-color: #cbd5e1;
                               -fx-border-radius: 8; -fx-padding: 10 16; -fx-font-size: 13px; -fx-cursor: hand;"/>
            </HBox>

            <!-- Tabela -->
            <TableView fx:id="tabelaMovimentacoes"
                       VBox.vgrow="ALWAYS" maxHeight="Infinity" minHeight="0"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                              -fx-table-cell-border-color: transparent; -fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colData"       text="Data / Hora"  prefWidth="145"/>
                    <TableColumn fx:id="colProduto"    text="Produto"       prefWidth="200"/>
                    <TableColumn fx:id="colTipo"       text="Tipo"          prefWidth="130"/>
                    <TableColumn fx:id="colQuantidade" text="Quantidade"    prefWidth="100"/>
                    <TableColumn fx:id="colUsuario"    text="Usuário"       prefWidth="150"/>
                    <TableColumn fx:id="colPedido"     text="Nº Pedido"     prefWidth="110"/>
                    <TableColumn fx:id="colNota"       text="Nota Fiscal"   prefWidth="110"/>
                    <TableColumn fx:id="colObservacao" text="Observação"    prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="Nenhuma movimentação encontrada."
                           style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </VBox>

    <!-- ── CAMADA 2: Overlay de detalhes ── -->
    <StackPane fx:id="overlayDetalhes"
               visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.45);">

        <VBox spacing="0" maxWidth="500"
              style="-fx-background-color: white; -fx-background-radius: 16;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0, 0, 4);">

            <!-- Cabeçalho azul -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #2563eb;
                         -fx-background-radius: 16 16 0 0; -fx-padding: 20 20 16 20;">
                <VBox HBox.hgrow="ALWAYS" spacing="4">
                    <Label text="Detalhes da Movimentação"
                           style="-fx-font-size: 13px; -fx-text-fill: #93c5fd;"/>
                    <Label fx:id="detalheProduto"
                           style="-fx-font-size: 17px; -fx-font-weight: bold;
                                  -fx-text-fill: white; -fx-wrap-text: true;"/>
                </VBox>
                <Button text="✕" onAction="#fecharDetalhes"
                        style="-fx-background-color: rgba(255,255,255,0.15);
                               -fx-text-fill: white; -fx-font-size: 14px;
                               -fx-background-radius: 50; -fx-cursor: hand;
                               -fx-border-color: transparent; -fx-padding: 6 10;"/>
            </HBox>

            <!-- Corpo -->
            <VBox spacing="0" style="-fx-padding: 20;">

                <!-- Tipo + Data -->
                <HBox spacing="24" style="-fx-padding: 0 0 16 0;
                      -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="TIPO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="detalheTipo"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-background-radius: 6; -fx-padding: 4 12;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="DATA / HORA"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="detalheData"
                               style="-fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                </HBox>

                <!-- Quantidade + Usuário -->
                <HBox spacing="24" style="-fx-padding: 16 0;
                      -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="QUANTIDADE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="detalheQuantidade"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="USUÁRIO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="detalheUsuario"
                               style="-fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                </HBox>

                <!-- Pedido + Nota -->
                <HBox spacing="24" style="-fx-padding: 16 0;
                      -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="Nº PEDIDO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="detalhePedido"
                               style="-fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="NOTA FISCAL"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="detalheNota"
                               style="-fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                </HBox>

                <!-- Observação / Motivo -->
                <VBox spacing="3" style="-fx-padding: 16 0 0 0;">
                    <Label text="OBSERVAÇÃO / MOTIVO"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                    <Label fx:id="detalheObservacao" wrapText="true"
                           style="-fx-font-size: 13px; -fx-text-fill: #334155;
                                  -fx-background-color: #f8fafc; -fx-background-radius: 8;
                                  -fx-padding: 10 12;"/>
                </VBox>
            </VBox>

            <!-- Rodapé -->
            <HBox alignment="CENTER_RIGHT"
                  style="-fx-padding: 16 20;
                         -fx-border-color: #f1f5f9 transparent transparent transparent;
                         -fx-border-width: 1;">
                <Button text="Fechar" onAction="#fecharDetalhes"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
