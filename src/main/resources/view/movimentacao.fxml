<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.movimentacaoController"
           style="-fx-background-color: #f0f2f5;">

    <VBox spacing="24" style="-fx-padding: 24;">
        <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                     -fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- ── Título ──────────────────────────────────────────────────── -->
            <VBox spacing="4" style="-fx-padding: 0 0 20 0;">
                <Label text="Movimentações de Estoque"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Histórico de entradas e saídas de produtos"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <!-- ── Filtros ─────────────────────────────────────────────────── -->
            <HBox spacing="12" style="-fx-padding: 0 0 20 0;" alignment="CENTER_LEFT">
                <TextField fx:id="fieldBusca"
                           promptText="🔍  Buscar por produto, usuário ou pedido"
                           prefWidth="280"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                <ComboBox fx:id="filtroTipo"
                          promptText="Todos os tipos"
                          prefWidth="170"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                <DatePicker fx:id="filtroDataInicio"
                            promptText="Data início" prefWidth="145"
                            style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                   -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                <DatePicker fx:id="filtroDataFim"
                            promptText="Data fim" prefWidth="145"
                            style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                   -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                <Button text="Limpar" onAction="#onLimparFiltros"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                               -fx-background-radius: 8; -fx-border-color: #cbd5e1;
                               -fx-border-radius: 8; -fx-padding: 10 16; -fx-font-size: 13px; -fx-cursor: hand;"/>
            </HBox>

            <!-- ── Tabela ──────────────────────────────────────────────────── -->
            <TableView fx:id="tabelaMovimentacoes"
                       VBox.vgrow="ALWAYS"
                       maxHeight="Infinity"
                       minHeight="0"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                              -fx-table-cell-border-color: transparent; -fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colData"       text="Data / Hora"   prefWidth="145"/>
                    <TableColumn fx:id="colProduto"    text="Produto"        prefWidth="200"/>
                    <TableColumn fx:id="colTipo"       text="Tipo"           prefWidth="130"/>
                    <TableColumn fx:id="colQuantidade" text="Quantidade"     prefWidth="100"/>
                    <TableColumn fx:id="colUsuario"    text="Usuário"        prefWidth="150"/>
                    <TableColumn fx:id="colPedido"     text="Nº Pedido"      prefWidth="110"/>
                    <TableColumn fx:id="colNota"       text="Nota Fiscal"    prefWidth="110"/>
                    <TableColumn fx:id="colObservacao" text="Observação"     prefWidth="200"/>
                </columns>
                <placeholder>
                    <Label text="Nenhuma movimentação encontrada."
                           style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </VBox>
</StackPane>
