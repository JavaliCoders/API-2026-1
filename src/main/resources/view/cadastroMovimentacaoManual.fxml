<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="api.controller.cadastroMovimentacaoManualController"
           style="-fx-background-color: #f0f2f5;">

    <VBox spacing="20" style="-fx-padding: 24;">

        <!-- Card principal -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                     -fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- Título + tipo -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 0 0 20 0;">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Nova Movimentação Manual"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Selecione o produto, tipo, quantidade e informe o motivo obrigatoriamente"
                           style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
                </VBox>
                <VBox spacing="6" alignment="CENTER_RIGHT">
                    <Label text="Tipo de operação"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ComboBox fx:id="comboTipo" prefWidth="180"
                              style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                     -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <!-- Busca de produto -->
            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
                <TextField fx:id="fieldBuscaProduto"
                           promptText="🔍  Buscar produto por nome ou COD"
                           prefWidth="340"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
            </HBox>

            <!-- Layout horizontal: tabela + formulário -->
            <HBox spacing="20" VBox.vgrow="ALWAYS">

                <!-- Tabela de produtos -->
                <TableView fx:id="tabelaProdutos" HBox.hgrow="ALWAYS"
                           prefHeight="300"
                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                  -fx-table-cell-border-color: transparent; -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colCod"      text="COD"       prefWidth="60"/>
                        <TableColumn fx:id="colProduto"  text="Produto"   prefWidth="200"/>
                        <TableColumn fx:id="colUnidade"  text="Un."       prefWidth="50"/>
                        <TableColumn fx:id="colSaldo"    text="Saldo"     prefWidth="75"/>
                        <TableColumn fx:id="colNivelMin" text="Nív. Mín." prefWidth="80"/>
                        <TableColumn fx:id="colStatus"   text="Status"    prefWidth="80"/>
                    </columns>
                    <placeholder>
                        <Label text="Nenhum produto encontrado."
                               style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>

                <!-- Formulário lateral -->
                <VBox spacing="14" minWidth="300" maxWidth="300"
                      style="-fx-background-color: #f8fafc; -fx-background-radius: 12;
                             -fx-border-color: #e2e8f0; -fx-border-radius: 12;
                             -fx-border-width: 1; -fx-padding: 20;">

                    <!-- Produto selecionado -->
                    <VBox spacing="4">
                        <Label text="PRODUTO SELECIONADO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelProdutoSelecionado"
                               text="Nenhum produto selecionado"
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <!-- Saldo atual -->
                    <VBox spacing="4">
                        <Label text="SALDO ATUAL"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelSaldoAtual" text="—"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    </VBox>

                    <!-- Badge tipo operação -->
                    <VBox spacing="4">
                        <Label text="TIPO DE OPERAÇÃO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelBadgeTipo" text="ENTRADA MANUAL"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-background-color: #dbeafe; -fx-text-fill: #1e40af;
                                      -fx-background-radius: 6; -fx-padding: 4 10;"/>
                    </VBox>

                    <!-- Quantidade -->
                    <VBox spacing="6">
                        <Label text="Quantidade"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="fieldQuantidade" promptText="Ex: 10"
                                   style="-fx-background-color: white; -fx-border-color: #cbd5e1;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 14px; -fx-text-fill: #0f172a;"/>
                    </VBox>

                    <!-- Motivo (obrigatório) -->
                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                        <Label text="Motivo / Observação  (obrigatório)"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextArea fx:id="fieldObservacao"
                                  promptText="Descreva o motivo da movimentação..."
                                  prefRowCount="4" wrapText="true"
                                  style="-fx-background-color: white; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    </VBox>

                    <!-- Aviso de validação -->
                    <Label fx:id="labelAviso" wrapText="true"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-background-color: #fee2e2; -fx-background-radius: 6;
                                  -fx-padding: 8 12;"/>

                    <!-- Botões -->
                    <HBox spacing="10">
                        <Button text="Cancelar" onAction="#onCancelar"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-padding: 10 16;
                                       -fx-cursor: hand; -fx-border-color: transparent;"/>
                        <Button fx:id="btnConfirmar" text="Confirmar Entrada"
                                onAction="#onConfirmar"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #16a34a; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8;
                                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-color: transparent;"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
