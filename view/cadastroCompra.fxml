<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.cadastroCompraController"
            style="-fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="20" style="-fx-padding: 24;" minWidth="760">

            <VBox spacing="4">
                <Label text="Registrar Compra"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Informe os dados da compra realizada"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Dados da Compra"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Pedido aprovado *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldPedido" promptText="Selecione o pedido"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroPedido" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Fornecedor *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldFornecedor" promptText="Selecione o fornecedor"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroFornecedor" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Comprador"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldComprador" editable="false"
                                   style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="190">
                        <Label text="Data da Compra"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldDataCompra" editable="false"
                                   style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="180">
                        <Label text="Data prevista"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <DatePicker fx:id="fieldDataPrevista" maxWidth="Infinity"
                                    style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                           -fx-border-radius: 8; -fx-background-radius: 8;
                                           -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Resumo do Pedido"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <HBox spacing="24" style="-fx-padding: 0 0 16 0;
                      -fx-border-color: transparent transparent #f1f5f9 transparent; -fx-border-width: 1;">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="SOLICITANTE"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelSolicitante" text="-"
                               style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="STATUS"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelStatusPedido" text="-"
                               style="-fx-font-size: 12px; -fx-font-weight: bold;
                                      -fx-background-radius: 6; -fx-padding: 4 12;"/>
                    </VBox>
                </HBox>

                <HBox spacing="24">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="SETOR"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelSetor" text="-"
                               style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="CENTRO DE CUSTO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelCentro" text="-"
                               style="-fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    </VBox>
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Label text="VALOR ESTIMADO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #94a3b8;"/>
                        <Label fx:id="labelValorEstimado" text="R$ 0,00"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Produtos da Compra"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <TableView fx:id="tabelaItens" editable="true" prefHeight="230"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colProduto" text="Produto" prefWidth="230"/>
                        <TableColumn fx:id="colUnidade" text="Un." prefWidth="55"/>
                        <TableColumn fx:id="colQtdSolicitada" text="Qtd Sol." prefWidth="85"/>
                        <TableColumn fx:id="colQtdCompra" text="Qtd Compra" prefWidth="100"/>
                        <TableColumn fx:id="colValorUnit" text="Valor Unit." prefWidth="110"/>
                        <TableColumn fx:id="colValorTotal" text="Valor Total" prefWidth="120"/>
                    </columns>
                    <placeholder>
                        <Label text="Selecione um pedido para carregar os produtos."
                               style="-fx-text-fill: #94a3b8;"/>
                    </placeholder>
                </TableView>

                <Label fx:id="erroItens" text=""
                       style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Label text="Valor Total da Compra:"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <Label fx:id="labelTotal" text="R$ 0,00"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                </HBox>
            </VBox>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#onCancelar"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
                <Button text="Salvar Compra" onAction="#onSalvar"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
