<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.editarPedidoController"
            style="-fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="20" style="-fx-padding: 24;" minWidth="700">

            <!-- Título -->
            <VBox spacing="4">
                <Label text="Editar Pedido"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Apenas pedidos com status EM APROVAÇÃO podem ser editados"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <!-- Card informações -->
            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Informações do Pedido"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <HBox spacing="16">
                    <VBox spacing="6" prefWidth="130">
                        <Label text="Nº Pedido"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldNumPedido" editable="false"
                                   style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox spacing="6" prefWidth="180">
                        <Label text="Data de Abertura"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldData" editable="false"
                                   style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Solicitante"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldSolicitante" editable="false"
                                   style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Setor *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldSetor" promptText="Selecione o setor"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroSetor" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Centro de Custo *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldCentroCusto" promptText="Selecione o centro de custo"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroCentro" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Card produtos -->
            <VBox spacing="16"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <Label text="Produtos do Pedido"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                <!-- Busca de produto -->
                <HBox spacing="12" alignment="BOTTOM_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Buscar Produto"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <HBox spacing="8">
                            <TextField fx:id="searchProduto"
                                       promptText="🔍  Nome ou código do produto"
                                       onKeyReleased="#onBuscarProduto"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                              -fx-border-radius: 8; -fx-background-radius: 8;
                                              -fx-padding: 10 14; -fx-font-size: 13px;"/>
                        </HBox>
                        <ListView fx:id="listaProdutos" prefHeight="130"
                                  visible="false" managed="false"
                                  style="-fx-background-color: white; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                    </VBox>

                    <VBox spacing="6" prefWidth="100">
                        <Label text="Quantidade *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldQtd" promptText="Ex: 5"
                                   style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px;"/>
                    </VBox>

                    <VBox spacing="6" prefWidth="130">
                        <Label text="Valor Unit."
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <TextField fx:id="fieldValorUnit" editable="false"
                                   style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb;
                                          -fx-border-radius: 8; -fx-background-radius: 8;
                                          -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                    </VBox>

                    <VBox spacing="6" alignment="BOTTOM_CENTER">
                        <Label text=" " style="-fx-font-size: 13px;"/>
                        <Button text="+ Adicionar" onAction="#onAdicionarProduto"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-padding: 10 20;
                                       -fx-cursor: hand; -fx-border-color: transparent;"/>
                    </VBox>
                </HBox>

                <!-- Produto selecionado -->
                <HBox fx:id="boxProdutoSelecionado" spacing="8" alignment="CENTER_LEFT"
                      visible="false" managed="false"
                      style="-fx-background-color: #eff6ff; -fx-background-radius: 8;
                             -fx-border-color: #bfdbfe; -fx-border-radius: 8; -fx-padding: 10 14;">
                    <Label text="✅" style="-fx-font-size: 13px;"/>
                    <Label fx:id="labelProdutoSelecionado" text=""
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#onLimparProduto"
                            style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                                   -fx-font-size: 12px; -fx-cursor: hand;
                                   -fx-border-color: transparent; -fx-padding: 2 6;"/>
                </HBox>

                <Label fx:id="erroProduto" text=""
                       style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>

                <!-- Tabela de itens -->
                <TableView fx:id="tabelaItens" prefHeight="200"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colProduto"  text="Produto"   prefWidth="200"/>
                        <TableColumn fx:id="colUnidade"  text="Un."       prefWidth="55"/>
                        <TableColumn fx:id="colQtd"      text="Qtd"       prefWidth="70"/>
                        <TableColumn fx:id="colVlrUnit"  text="Vlr Unit." prefWidth="100"/>
                        <TableColumn fx:id="colVlrTotal" text="Vlr Total" prefWidth="110"/>
                        <TableColumn fx:id="colRemover"  text=""          prefWidth="60"/>
                    </columns>
                    <placeholder>
                        <Label text="Nenhum produto adicionado."
                               style="-fx-text-fill: #94a3b8;"/>
                    </placeholder>
                </TableView>

                <!-- Total -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Label text="Valor Total Estimado:"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <Label fx:id="labelTotal" text="R$ 0,00"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                </HBox>
            </VBox>

            <!-- Botões -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancelar" onAction="#onCancelar"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
                <Button text="Salvar Alterações" onAction="#onSalvar"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 24;
                               -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>