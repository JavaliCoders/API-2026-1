<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.cadastroFornecedorController"
            style="-fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true"
                hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;"
                AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="20" style="-fx-padding: 24;" minWidth="600">

            <VBox spacing="4">
                <Label fx:id="labelTitulo" text="Cadastro de Fornecedor"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label fx:id="labelSubtitulo" text="Preencha os dados do novo fornecedor"
                       style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>

            <VBox spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 2);
                         -fx-padding: 24;">

                <!-- Linha 1: Nome -->
                <VBox spacing="6">
                    <Label text="Nome *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <TextField fx:id="fieldNome" promptText="Ex: Distribuidora ABC Ltda"
                               style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="erroNome" text=""
                           style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Linha 2: CNPJ -->
                <VBox spacing="6">
                    <Label text="CNPJ *"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <TextField fx:id="fieldCnpj" promptText="Ex: 00000000000000"
                               style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="erroCnpj" text=""
                           style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Linha 3: Tipo Pagamento + Status -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tipo de Pagamento *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldTipoPagamento" promptText="Selecione"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroTipoPagamento" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="6" prefWidth="160">
                        <Label text="Status *"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <ComboBox fx:id="fieldStatus" promptText="Selecione"
                                  prefWidth="160"
                                  style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                         -fx-border-radius: 8; -fx-background-radius: 8;
                                         -fx-font-size: 13px;"/>
                        <Label fx:id="erroStatus" text=""
                               style="-fx-text-fill: #ef4444; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <!-- Linha 4: Pedido Mínimo -->
                <VBox spacing="6" prefWidth="200">
                    <Label text="Pedido Mínimo (R$)"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <TextField fx:id="fieldPedidoMinimo" promptText="Ex: 500,00"
                               style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 10 14; -fx-font-size: 13px; -fx-text-fill: #0f172a;"/>
                    <Label text="Campo opcional."
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
                </VBox>

                <!-- Botões -->
                <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                    <Button text="Cancelar" onAction="#onCancelar"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 10 24;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                    <Button text="Salvar Fornecedor" onAction="#onSalvar"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 10 24;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>