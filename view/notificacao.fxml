<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="api.controller.notificacaoController"
            style="-fx-background-color: #f0f2f5;">

    <VBox spacing="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ── Cabeçalho da seção ─────────────────────────── -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: white; -fx-padding: 20 28;
                     -fx-border-color: transparent transparent #e5e7eb transparent;
                     -fx-border-width: 1;">

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="🔔  Notificações"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label fx:id="labelTotalNaoLidas"
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
            </VBox>

            <!-- Botão recarregar -->
            <Button text="↺  Atualizar"
                    onAction="#onRecarregar"
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                           -fx-font-size: 13px; -fx-background-radius: 8;
                           -fx-border-color: transparent; -fx-padding: 8 16; -fx-cursor: hand;"/>

            <!-- Botão limpar notificações lidas -->
            <Button fx:id="btnLimparLidas" text="🗑  Limpar lidas"
                    onAction="#onLimparLidas"
                    style="-fx-background-color: #fee2e2; -fx-text-fill: #dc2626;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-border-color: transparent;
                           -fx-padding: 8 16; -fx-cursor: hand;"/>

            <!-- Botão marcar todas como lidas -->
            <Button fx:id="btnMarcarTodas" text="✓  Marcar todas como lidas"
                    onAction="#onMarcarTodas"
                    style="-fx-background-color: #2563eb; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13px;
                           -fx-background-radius: 8; -fx-border-color: transparent;
                           -fx-padding: 8 16; -fx-cursor: hand;"/>
        </HBox>

        <!-- ── Área de scroll com os cards ──────────────────── -->
        <ScrollPane fx:id="scrollNotificacoes" fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;
                           -fx-border-color: transparent; -fx-padding: 0;">

            <VBox fx:id="listaNotificacoes" spacing="0"
                  style="-fx-background-color: transparent; -fx-padding: 24 28;">

                <!-- Cards criados dinamicamente pelo controller -->

                <!-- Placeholder quando não há notificações -->
                <VBox fx:id="labelVazia" alignment="CENTER" spacing="12"
                      style="-fx-padding: 60 0 0 0;" visible="false" managed="false">
                    <Label text="🔔"
                           style="-fx-font-size: 48px;"/>
                    <Label text="Nenhuma notificação"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <Label text="Você está em dia! Novas notificações aparecerão aqui."
                           style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;"/>
                </VBox>

            </VBox>
        </ScrollPane>

    </VBox>
</AnchorPane>
