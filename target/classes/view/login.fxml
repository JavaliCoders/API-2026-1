<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:controller="api.controller.LoginController"
            prefHeight="600.0"
            prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox alignment="CENTER"
              styleClass="content"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <VBox alignment="CENTER" maxWidth="340.0" spacing="14.0" styleClass="card">
                <Label minHeight="52.0" minWidth="52.0" styleClass="icon" text="&gt;" />
                <Label styleClass="title" text="Bem-vindo de volta" />
                <Label styleClass="subtitle"
                       text="Entre com suas credenciais para acessar o sistema"
                       textAlignment="CENTER"
                       wrapText="true" />

                <VBox spacing="6.0" styleClass="field-group">
                    <Label styleClass="form-label" text="Usuario ou e-mail" />
                    <TextField fx:id="txtIdentificador"
                               onKeyTyped="#aoDigitar"
                               promptText="diretor ou diretor@email.com" />
                </VBox>

                <VBox spacing="6.0" styleClass="field-group">
                    <Label styleClass="form-label" text="Senha" />
                    <PasswordField fx:id="txtSenha"
                                   onKeyTyped="#aoDigitar"
                                   promptText="********" />
                </VBox>

                <Label fx:id="lblMensagem"
                       managed="false"
                       styleClass="feedback-label"
                       text=""
                       visible="false"
                       wrapText="true" />

                <Button defaultButton="true"
                        maxWidth="1.7976931348623157E308"
                        onAction="#entrar"
                        styleClass="btn"
                        text="Entrar" />

                <Label styleClass="support-text"
                       text="Problemas com o acesso? Entre em contato com o administrador."
                       textAlignment="CENTER"
                       wrapText="true" />
            </VBox>
        </VBox>
    </children>
</AnchorPane>
